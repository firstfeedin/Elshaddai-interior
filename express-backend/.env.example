# El Shaddai Backend — copy to .env and fill in real values

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated production frontend URLs (Vercel domains)
ALLOWED_ORIGINS=https://elshaddai.vercel.app,https://elshaddai-git-main.vercel.app

# ── Database ──────────────────────────────────────────────────
# On Railway: mount a volume at /data and set DB_PATH=/data/elshaddai.sqlite
# Locally: leave empty (defaults to ./elshaddai.sqlite)
DB_PATH=

# ── Contact Form Email ────────────────────────────────────────
SMTP_USER=your.gmail@gmail.com
SMTP_PASS=your_16_char_app_password
CONTACT_TO=contactus@elshaddai.in

# ── Server ────────────────────────────────────────────────────
PORT=3001
