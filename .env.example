# El Shaddai Frontend — copy to .env.local and fill in values
# NEVER commit .env or .env.local to git

# ── Backend API ──────────────────────────────────────────────────────────────
# Point to your Railway backend URL (with /api suffix)
# Leave empty for local dev — Vite proxies /api → localhost:3001 automatically
VITE_API_URL=https://your-backend.up.railway.app/api

# ── Google OAuth ──────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Google Analytics ──────────────────────────────────────────────────────────
VITE_GA_ID=G-XXXXXXXXXX

# ── Gemini AI ─────────────────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=your-gemini-api-key
