// El Shaddai Interior Design Platform — Prisma Schema v2
// PRD Section 8 — Complete Database Design

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  DESIGNER
  BUILDER
  WORKSHOP_WORKER
  CLIENT
}

enum ProjectStatus {
  INQUIRY
  QUOTATION
  CONCEPT
  DESIGN
  PROCUREMENT
  EXECUTION
  HANDOVER
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  DESIGN
  PROCUREMENT
  FABRICATION
  INSTALLATION
  INSPECTION
  DOCUMENTATION
  MEETING
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
}

enum AssetType {
  FLOOR_PLAN
  ELEVATION
  MOOD_BOARD
  RENDER_2D
  RENDER_3D
  BOQ
  CONTRACT
  PHOTO
  VIDEO
  OTHER
}

enum ExpenseCategory {
  MATERIAL
  LABOUR
  TRANSPORT
  EQUIPMENT
  SUBCONTRACTOR
  OVERHEAD
  OTHER
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum PropertyType {
  APARTMENT
  VILLA
  INDEPENDENT_HOUSE
  COMMERCIAL_OFFICE
  RETAIL_SHOP
  RESTAURANT
  HOSPITALITY
  OTHER
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
  FAILED
}

// ─── ORGANISATION ─────────────────────────────────────────────────────────────

model Organisation {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  logo           String?
  website        String?
  phone          String?
  address        String?
  city           String?
  state          String?
  gst_number     String?
  pan_number     String?
  subscription   SubscriptionPlan @default(FREE)
  sub_expires_at DateTime?
  settings       Json             @default("{}")
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt

  users    User[]
  projects Project[]

  @@map("organisations")
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  org_id         String?
  email          String    @unique
  password_hash  String?
  name           String
  phone          String?
  avatar         String?
  role           Role      @default(CLIENT)
  profile_data   Json      @default("{}")
  mfa_enabled    Boolean   @default(false)
  mfa_secret     String?
  google_id      String?   @unique
  email_verified Boolean   @default(false)
  is_active      Boolean   @default(true)
  last_login     DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  organisation         Organisation?      @relation(fields: [org_id], references: [id])
  refresh_tokens       RefreshToken[]
  projects_as_client   Project[]          @relation("ClientProjects")
  projects_as_designer Project[]          @relation("DesignerProjects")
  tasks_assigned       Task[]             @relation("AssignedTasks")
  tasks_created        Task[]             @relation("CreatedTasks")
  time_logs            TimeLog[]
  expenses             Expense[]
  messages_sent        Message[]
  design_assets        DesignAsset[]
  consultations        Consultation[]
  testimonials         Testimonial[]
  portfolio_items      PortfolioProject[]
  orders               Order[]

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(cuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  device     String?
  ip         String?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── PROJECT ──────────────────────────────────────────────────────────────────

model Project {
  id              String        @id @default(cuid())
  org_id          String?
  project_number  String        @unique
  name            String
  client_id       String
  designer_id     String?
  property_type   PropertyType  @default(APARTMENT)
  status          ProjectStatus @default(INQUIRY)
  address         String?
  city            String?
  total_area_sqft Decimal?      @db.Decimal(10, 2)
  budget          Decimal?      @db.Decimal(12, 2)
  quoted_amount   Decimal?      @db.Decimal(12, 2)
  approved_amount Decimal?      @db.Decimal(12, 2)
  start_date      DateTime?
  end_date        DateTime?
  actual_end_date DateTime?
  description     String?
  requirements    Json          @default("{}")
  scene_data      Json          @default("{}")
  ai_design_data  Json          @default("{}")
  metadata        Json          @default("{}")
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  organisation  Organisation? @relation(fields: [org_id], references: [id])
  client        User          @relation("ClientProjects", fields: [client_id], references: [id])
  designer      User?         @relation("DesignerProjects", fields: [designer_id], references: [id])
  tasks         Task[]
  expenses      Expense[]
  messages      Message[]
  design_assets DesignAsset[]
  quotations    Quotation[]
  orders        Order[]
  milestones    Milestone[]
  daily_logs    DailyLog[]

  @@index([client_id])
  @@index([status])
  @@map("projects")
}

// ─── TASK ─────────────────────────────────────────────────────────────────────

model Task {
  id            String       @id @default(cuid())
  project_id    String
  parent_id     String?
  title         String
  description   String?
  type          TaskType     @default(OTHER)
  status        TaskStatus   @default(TODO)
  priority      TaskPriority @default(MEDIUM)
  assignee_id   String?
  creator_id    String
  due_date      DateTime?
  estimated_hrs Decimal?     @db.Decimal(6, 2)
  actual_hrs    Decimal?     @db.Decimal(6, 2)
  tags          String[]
  attachments   String[]
  position      Int          @default(0)
  metadata      Json         @default("{}")
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  project      Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  parent       Task?            @relation("SubTasks", fields: [parent_id], references: [id])
  sub_tasks    Task[]           @relation("SubTasks")
  assignee     User?            @relation("AssignedTasks", fields: [assignee_id], references: [id])
  creator      User             @relation("CreatedTasks", fields: [creator_id], references: [id])
  time_logs    TimeLog[]
  dependencies TaskDependency[] @relation("DependentTask")
  blocks       TaskDependency[] @relation("BlockingTask")

  @@index([project_id, status])
  @@map("tasks")
}

model TaskDependency {
  id         String @id @default(cuid())
  task_id    String
  depends_on String

  task     Task @relation("DependentTask", fields: [task_id], references: [id], onDelete: Cascade)
  blocking Task @relation("BlockingTask", fields: [depends_on], references: [id], onDelete: Cascade)

  @@unique([task_id, depends_on])
  @@map("task_dependencies")
}

// ─── TIME LOGS ────────────────────────────────────────────────────────────────

model TimeLog {
  id           String    @id @default(cuid())
  task_id      String?
  project_id   String?
  user_id      String
  description  String?
  started_at   DateTime
  ended_at     DateTime?
  duration_min Int?
  billable     Boolean   @default(true)
  created_at   DateTime  @default(now())

  task Task? @relation(fields: [task_id], references: [id], onDelete: SetNull)
  user User  @relation(fields: [user_id], references: [id])

  @@index([user_id, started_at])
  @@map("time_logs")
}

// ─── EXPENSES ─────────────────────────────────────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  project_id  String
  user_id     String
  category    ExpenseCategory @default(MATERIAL)
  description String
  amount      Decimal         @db.Decimal(12, 2)
  gst_rate    Decimal?        @db.Decimal(5, 2)
  gst_amount  Decimal?        @db.Decimal(12, 2)
  vendor      String?
  invoice_no  String?
  receipt_url String?
  date        DateTime        @default(now())
  approved    Boolean         @default(false)
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id])

  @@index([project_id])
  @@map("expenses")
}

// ─── MESSAGES ─────────────────────────────────────────────────────────────────

model Message {
  id         String      @id @default(cuid())
  project_id String
  sender_id  String
  type       MessageType @default(TEXT)
  content    String
  file_url   String?
  metadata   Json        @default("{}")
  read_by    String[]
  created_at DateTime    @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [sender_id], references: [id])

  @@index([project_id, created_at])
  @@map("messages")
}

// ─── DESIGN ASSETS ────────────────────────────────────────────────────────────

model DesignAsset {
  id          String    @id @default(cuid())
  project_id  String
  uploader_id String
  type        AssetType @default(OTHER)
  name        String
  url         String
  thumbnail   String?
  size_bytes  Int?
  mime_type   String?
  version     Int       @default(1)
  tags        String[]
  metadata    Json      @default("{}")
  created_at  DateTime  @default(now())

  project  Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  uploader User    @relation(fields: [uploader_id], references: [id])

  @@map("design_assets")
}

// ─── MILESTONES ───────────────────────────────────────────────────────────────

model Milestone {
  id             String    @id @default(cuid())
  project_id     String
  name           String
  description    String?
  due_date       DateTime
  completed      Boolean   @default(false)
  completed_at   DateTime?
  payment_amount Decimal?  @db.Decimal(12, 2)
  payment_paid   Boolean   @default(false)
  created_at     DateTime  @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("milestones")
}

// ─── DAILY LOGS ───────────────────────────────────────────────────────────────

model DailyLog {
  id              String   @id @default(cuid())
  project_id      String
  date            DateTime
  summary         String
  photos          String[]
  workers_present Int      @default(0)
  issues          String?
  created_at      DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([project_id, date])
  @@map("daily_logs")
}

// ─── QUOTATIONS ───────────────────────────────────────────────────────────────

model Quotation {
  id          String    @id @default(cuid())
  project_id  String
  version     Int       @default(1)
  items       Json      @default("[]")
  subtotal    Decimal   @db.Decimal(12, 2)
  gst_amount  Decimal   @db.Decimal(12, 2)
  total       Decimal   @db.Decimal(12, 2)
  valid_until DateTime?
  approved    Boolean   @default(false)
  approved_at DateTime?
  notes       String?
  pdf_url     String?
  created_at  DateTime  @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("quotations")
}

// ─── ORDERS ───────────────────────────────────────────────────────────────────

model Order {
  id           String        @id @default(cuid())
  project_id   String
  client_id    String
  order_number String        @unique
  items        Json          @default("[]")
  total        Decimal       @db.Decimal(12, 2)
  paid         Decimal       @default(0) @db.Decimal(12, 2)
  status       PaymentStatus @default(PENDING)
  stages       Json          @default("[]")
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  project  Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  client   User      @relation(fields: [client_id], references: [id])
  payments Payment[]

  @@map("orders")
}

model Payment {
  id          String        @id @default(cuid())
  order_id    String
  amount      Decimal       @db.Decimal(12, 2)
  gateway     String        @default("razorpay")
  gateway_ref String?
  status      PaymentStatus @default(PENDING)
  paid_at     DateTime?
  created_at  DateTime      @default(now())

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── CONSULTATIONS / LEADS ────────────────────────────────────────────────────

model Consultation {
  id            String        @id @default(cuid())
  user_id       String?
  name          String
  email         String
  phone         String
  city          String?
  property_type PropertyType?
  budget_range  String?
  message       String?
  status        LeadStatus    @default(NEW)
  assigned_to   String?
  notes         String?
  follow_up_at  DateTime?
  source        String        @default("website")
  metadata      Json          @default("{}")
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  user User? @relation(fields: [user_id], references: [id])

  @@index([status])
  @@map("consultations")
}

// ─── PORTFOLIO ────────────────────────────────────────────────────────────────

model PortfolioProject {
  id          String   @id @default(cuid())
  designer_id String?
  title       String
  description String?
  category    String?
  style       String?
  area_sqft   Decimal? @db.Decimal(10, 2)
  city        String?
  images      String[]
  tags        String[]
  featured    Boolean  @default(false)
  views       Int      @default(0)
  created_at  DateTime @default(now())

  designer User? @relation(fields: [designer_id], references: [id])

  @@map("portfolio_projects")
}

// ─── TESTIMONIALS ─────────────────────────────────────────────────────────────

model Testimonial {
  id           String   @id @default(cuid())
  client_id    String?
  client_name  String
  location     String?
  avatar       String?
  rating       Int      @default(5)
  text         String
  project_type String?
  verified     Boolean  @default(false)
  featured     Boolean  @default(false)
  created_at   DateTime @default(now())

  client User? @relation(fields: [client_id], references: [id])

  @@map("testimonials")
}

// ─── FURNITURE / MATERIALS CATALOG ────────────────────────────────────────────

model FurnitureItem {
  id          String   @id @default(cuid())
  name        String
  category    String
  subcategory String?
  price       Decimal  @db.Decimal(10, 2)
  thumbnail   String?
  model_url   String?
  dimensions  Json?
  materials   String[]
  colors      String[]
  styles      String[]
  tags        String[]
  in_stock    Boolean  @default(true)
  created_at  DateTime @default(now())

  @@map("furniture_items")
}

model Material {
  id             String   @id @default(cuid())
  name           String
  category       String
  finish         String?
  color_hex      String?
  texture_url    String?
  price_per_sqft Decimal  @db.Decimal(8, 2)
  brand          String?
  tags           String[]
  in_stock       Boolean  @default(true)
  created_at     DateTime @default(now())

  @@map("materials")
}
